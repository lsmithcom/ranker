# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ranker

# Session (nuxt-auth-utils requires this - generate a strong 32+ char random string)
NUXT_SESSION_PASSWORD=your-super-secret-session-password-min-32-chars

# Encryption key for storing GSC OAuth tokens
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Google Search Console OAuth 2.0
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
